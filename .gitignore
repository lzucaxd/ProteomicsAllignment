# Data (large / local — not tracked)
data/pdc/
data/pdc_psm/
data/ccle_peptide/
data/results/

# PDC file-manifest exports (signed URLs expire; obtain fresh CSVs — see data/manifests/README.md)
data/manifests/PDC_file_manifest_*.csv
data/manifests/PDC*_pdc_file_manifest.csv

# Optional local processed copy (use configs/preprocessing/union.yaml paths instead)
data/processed_union/

# Ad-hoc local datasets
data/MSI VS MSS/
*.mzML
*.mzXML
*.raw

# Processed union + method matrices (tracked for reproducibility)
!data/processed/union/*.csv
!data/processed/methods/*/transformed_*.csv

# Reports: track canonical summaries; ignore heavy logs
!reports/benchmark_master/benchmark_results/comparison_summary.csv
!reports/benchmark_master/benchmark_results/disconnect_scores.csv
reports/benchmark_master/logs/
*.log

# Presentation bundle (large; regenerate via scripts/presentation/prepare_all.sh)
presentation_materials/

# R default plot output (often created at cwd)
Rplots.pdf
MSstats_groupComparison_log_*.log
MSstats_dataProcess_log_*.log

# Vendored Celligner: local builds
models/celligner-master/mnnpy/build/
models/celligner-master/**/__pycache__/

# Archive (legacy copies; keep README only)
archive/*
!archive/README.md
